{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ernos-labs.example/schemas/sft-empirical-registration-v3.json",
  "title": "SFT v3 empirical registration",
  "type": "object",
  "required": [
    "experiment_id",
    "claim_id",
    "development_observations",
    "frozen_relation",
    "inputs",
    "withheld_targets",
    "metrics",
    "controls",
    "target_access_policy",
    "status"
  ],
  "properties": {
    "experiment_id": {"type": "string", "minLength": 1},
    "claim_id": {"type": "string", "minLength": 1},
    "development_observations": {"type": "array", "items": {"type": "string"}},
    "frozen_relation": {"type": "string", "minLength": 1},
    "inputs": {"type": "array", "items": {"type": "string"}},
    "withheld_targets": {"type": "array", "items": {"type": "string"}},
    "metrics": {"type": "array", "items": {"type": "string"}},
    "controls": {"type": "array", "items": {"type": "string"}},
    "target_access_policy": {"const": "structurally-denied-before-seal"},
    "status": {"enum": ["registered", "executed", "sealed", "measured", "superseded"]},
    "source_hashes": {"type": "object"},
    "registration_date": {"type": ["string", "null"]},
    "registered_by": {"type": "string"}
  },
  "additionalProperties": false
}
