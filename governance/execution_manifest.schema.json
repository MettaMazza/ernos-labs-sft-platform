{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ernos-labs.example/schemas/sft-execution-manifest-v3.json",
  "title": "SFT v3 complete claim execution manifest",
  "type": "object",
  "required": ["schema", "claims"],
  "properties": {
    "schema": {"const": "sft-v3-execution-manifest/1"},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "execution_file"],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "execution_file": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
